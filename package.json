{
  "name": "excel-cli",
  "version": "1.0.0",
  "description": "Read Excel files (xlsx, xls, ods) and output as CSV in the terminal",
  "type": "module",
  "bin": { "excel-cli": "./bin/excel-cli.js" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": { "node": ">=18.0.0" },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noxymon/excel-cli.git"
  },
  "homepage": "https://github.com/noxymon/excel-cli#readme",
  "bugs": {
    "url": "https://github.com/noxymon/excel-cli/issues"
  },
  "author": "noxymon",
  "keywords": ["excel", "xlsx", "xls", "ods", "cli", "csv", "spreadsheet"],
  "files": ["bin", "dist", "package.json", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "xlsx": "^0.18.5",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
